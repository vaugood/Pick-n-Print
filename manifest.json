{
  "manifest_version": 3,
  "name": "Element Print Picker",
  "version": "0.1.0",
  "description": "Pick specific elements on a page and print only those elements.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Element Print Picker"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "background": {
    "service_worker": "service_worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}